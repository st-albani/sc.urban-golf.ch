# Backend Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/urban_golf
DATABASE_SSL=false

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# Email notification (Brevo/Sendinblue SMTP - optional)
# BREVO_SMTP_USER=your-brevo-login@email.com
# BREVO_SMTP_PASS=your-brevo-smtp-key

# Admin notification email for feedback (optional)
# ADMIN_EMAIL=admin@urban-golf.ch

# Auth / Sessions (optionale Identität via E-Mail-OTP)
# AUTH_PEPPER: serverseitiger Zusatz für OTP-/Token-Hashes (optional, empfohlen in Prod)
# AUTH_PEPPER=change-me-random-secret
# COOKIE_DOMAIN: Domain für das Session-Cookie (optional, z.B. .urban-golf.ch für Subdomains)
# COOKIE_DOMAIN=
